* text=auto

# Keep common source and project files normalized as text.
*.cs text
*.csproj text
*.props text
*.targets text
*.sln text
*.slnx text
*.json text
*.jsonc text
*.xml text
*.yml text
*.yaml text
*.md text
*.txt text
*.ps1 text
*.sh text eol=lf

# Unity and Godot assets that are text-serialized should remain diffable.
*.asmdef text
*.asset text
*.controller text
*.mat text
*.meta text
*.prefab text
*.scene text
*.tscn text
*.tres text
*.unity text

# Large binary assets used by Unity/Godot samples.
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.psb filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text
*.cubemap filter=lfs diff=lfs merge=lfs -text

